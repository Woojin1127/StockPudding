# 로컬 개발용 환경 변수 — 복사해서 .env 로 사용하세요 (.env는 커밋 금지)

# Python 분석 엔진 주소 (생략 시 http://localhost:8000)
VITE_ENGINE_URL=http://localhost:8000

# Supabase 연결 (미설정이어도 검색·분석은 동작, 저장·투표는 로컬 폴백)
# 발급: https://supabase.com → 프로젝트 → Settings → API Keys / Data API
# URL: "Project URL" (https://xxxx.supabase.co)
# 키: 신형 "sb_publishable_..." 또는 구형 "anon public" 키 — 둘 다 클라이언트 노출 OK
# 단 "sb_secret_..." / "service_role" 키는 절대 넣지 말 것!
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
